# =====================================================================
# Variables de Entorno - Sistema de Monitoreo de Orquídeas
# Copia este archivo como .env y rellena tus valores reales
# =====================================================================

# Base de datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=orchid_monitoring
DB_PORT=3306

# Servidor
PORT=3000
NODE_ENV=development

# Seguridad
SESSION_SECRET=cambia_esto_por_algo_aleatorio

# Sensores
ENABLE_SENSOR_SIMULATION=true
SENSOR_SIMULATION_INTERVAL=5
