<%- include('partials/header') %>

<div class="container">
    <div class="page-header">
        <h1 class="page-title">Historial de Datos</h1>
        <p class="page-subtitle">Análisis de las condiciones ambientales registradas</p>
    </div>

    <!-- Filtros -->
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title">Filtros de Búsqueda</h3>
            <span class="card-icon">🔍</span>
        </div>
        <div class="card-body">
            <form method="GET" action="/history" class="flex gap-2" style="align-items: flex-end;">
                <div class="form-group" style="flex: 1; margin-bottom: 0;">
                    <label class="form-label">Período de Tiempo</label>
                    <select class="form-select" name="period" onchange="this.form.submit()">
                        <option value="24" <%= period == '24' ? 'selected' : '' %>>Últimas 24 horas</option>
                        <option value="48" <%= period == '48' ? 'selected' : '' %>>Últimos 2 días</option>
                        <option value="168" <%= period == '168' ? 'selected' : '' %>>Última semana</option>
                        <option value="720" <%= period == '720' ? 'selected' : '' %>>Último mes</option>
                    </select>
                </div>
                <button type="button" class="btn btn-secondary" onclick="exportData()">
                    📥 Exportar CSV
                </button>
            </form>
        </div>
    </div>

    <!-- Estadísticas del Período -->
    <div class="cards-grid mb-3">
        <div class="card stat-card">
            <div class="card-header">
                <h3 class="card-title">Humedad Promedio</h3>
                <span class="card-icon">💧</span>
            </div>
            <div class="card-body">
                <div class="stat-value" style="color: var(--secondary-color);">
                    <% 
                    const avgHumidity = readings.length > 0 
                        ? (readings.reduce((sum, r) => sum + parseFloat(r.humidity), 0) / readings.length).toFixed(1)
                        : 0;
                    %>
                    <%= avgHumidity %>%
                </div>
                <div class="stat-label">
                    Período: <%= period %>h
                </div>
            </div>
        </div>

        <div class="card stat-card">
            <div class="card-header">
                <h3 class="card-title">Temperatura Promedio</h3>
                <span class="card-icon">🌡️</span>
            </div>
            <div class="card-body">
                <div class="stat-value" style="color: var(--warning-color);">
                    <% 
                    const avgTemp = readings.length > 0 
                        ? (readings.reduce((sum, r) => sum + parseFloat(r.temperature), 0) / readings.length).toFixed(1)
                        : 0;
                    %>
                    <%= avgTemp %>°C
                </div>
                <div class="stat-label">
                    Período: <%= period %>h
                </div>
            </div>
        </div>

        <div class="card stat-card">
            <div class="card-header">
                <h3 class="card-title">Total de Lecturas</h3>
                <span class="card-icon">📊</span>
            </div>
            <div class="card-body">
                <div class="stat-value" style="color: var(--primary-color);">
                    <%= readings.length %>
                </div>
                <div class="stat-label">
                    Registros totales
                </div>
            </div>
        </div>

        <div class="card stat-card">
            <div class="card-header">
                <h3 class="card-title">Alertas Generadas</h3>
                <span class="card-icon">⚠️</span>
            </div>
            <div class="card-body">
                <div class="stat-value" style="color: var(--danger-color);">
                    <% 
                    const alertCount = readings.filter(r => r.alert_triggered).length;
                    %>
                    <%= alertCount %>
                </div>
                <div class="stat-label">
                    Fuera de rango
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de Tendencias -->
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title">Tendencias Históricas</h3>
            <span class="card-icon">📈</span>
        </div>
        <div class="card-body">
            <canvas id="history-chart"></canvas>
        </div>
    </div>

    <!-- Tabla de Datos -->
    <div class="table-container">
        <div class="flex-between mb-2">
            <h3 class="card-title">Registros Detallados</h3>
            <span class="text-secondary"><%= readings.length %> registros</span>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Sensor</th>
                    <th>Humedad (%)</th>
                    <th>Temperatura (°C)</th>
                    <th>Fecha y Hora</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                <% if (readings.length === 0) { %>
                <tr>
                    <td colspan="6" class="text-center">No hay datos disponibles para el período seleccionado</td>
                </tr>
                <% } else { %>
                    <% readings.forEach(reading => { 
                        const humidityOk = reading.humidity >= 75 && reading.humidity <= 85;
                        const tempOk = reading.temperature >= 18 && reading.temperature <= 24;
                        const status = humidityOk && tempOk ? 'normal' : 'warning';
                    %>
                    <tr>
                        <td>#<%= reading.id %></td>
                        <td><strong><%= reading.sensor_name %></strong></td>
                        <td class="<%= humidityOk ? 'trend-up' : 'trend-down' %>">
                            <%= reading.humidity %>%
                        </td>
                        <td class="<%= tempOk ? 'trend-up' : 'trend-down' %>">
                            <%= reading.temperature %>°C
                        </td>
                        <td><%= new Date(reading.timestamp).toLocaleString('es-CL') %></td>
                        <td>
                            <span class="status-badge <%= status === 'normal' ? 'status-active' : 'status-warning' %>">
                                <%= status === 'normal' ? '✓ Óptimo' : '⚠ Alerta' %>
                            </span>
                        </td>
                    </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const readings = <%- JSON.stringify(readings) %>;
    
    // Preparar datos para el gráfico
    const chartData = {
        labels: readings.map(r => new Date(r.timestamp).toLocaleString('es-CL', { 
            month: 'short', 
            day: 'numeric', 
            hour: '2-digit', 
            minute: '2-digit' 
        })),
        datasets: [
            {
                label: 'Humedad (%)',
                data: readings.map(r => parseFloat(r.humidity)),
                borderColor: 'rgb(6, 182, 212)',
                backgroundColor: 'rgba(6, 182, 212, 0.1)',
                yAxisID: 'y',
                tension: 0.4
            },
            {
                label: 'Temperatura (°C)',
                data: readings.map(r => parseFloat(r.temperature)),
                borderColor: 'rgb(245, 158, 11)',
                backgroundColor: 'rgba(245, 158, 11, 0.1)',
                yAxisID: 'y1',
                tension: 0.4
            }
        ]
    };

    const config = {
        type: 'line',
        data: chartData,
        options: {
            responsive: true,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            plugins: {
                legend: {
                    position: 'top',
                },
                title: {
                    display: false
                }
            },
            scales: {
                y: {
                    type: 'linear',
                    display: true,
                    position: 'left',
                    title: {
                        display: true,
                        text: 'Humedad (%)'
                    }
                },
                y1: {
                    type: 'linear',
                    display: true,
                    position: 'right',
                    title: {
                        display: true,
                        text: 'Temperatura (°C)'
                    },
                    grid: {
                        drawOnChartArea: false,
                    }
                }
            }
        }
    };

    const chart = new Chart(document.getElementById('history-chart'), config);

    // Función para exportar datos
    function exportData() {
        if (readings.length === 0) {
            alert('No hay datos para exportar');
            return;
        }

        let csv = 'ID,Sensor,Humedad (%),Temperatura (°C),Fecha y Hora\n';
        readings.forEach(r => {
            csv += `${r.id},${r.sensor_name},${r.humidity},${r.temperature},"${new Date(r.timestamp).toLocaleString('es-CL')}"\n`;
        });

        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `historial_orquideas_${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
    }
</script>

<%- include('partials/footer') %>